{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"name": "unimap",
	"scopeName": "source.unimap",
	"patterns": [
		{ "include": "#comment" },
		{ "include": "#keywords" },
		{ "include": "#operators" },
		{ "include": "#punctuation" },
		{ "include": "#nb" },
		{ "include": "#identifiers" }
	],
	"repository": {
		"comment": {
			"patterns": [
				{
					"name": "comment.line.unimap",
					"match": "//.*$"
				}, {
					"name": "comment.block.unimap",
					"begin": "/\\*",
					"end": "\\*/"
				}
			]
		},
		"keywords": {
			"patterns": [{
				"name": "keyword.unimap",
				"match": "(?<=^|\\s|[.:,;=|/(){}\\[\\]])(fn|let|import|symbol)(?=\\s|[.:,;=|/(){}\\[\\]])"
			}]
		},
		"operators": {
			"patterns": [
				{
					"match": "=",
					"name": "keyword.operator.assignment.unimap"
				}, {
					"match": "=>",
					"name": "keyword.operator.arrow.unimap"
				}, {
		  			"match": "\\|>",
					"name": "keyword.operator.pipeline.unimap"
				}, {
					"match": "\\.\\.",
					"name": "keyword.operator.spread.unimap"
				}, {
					"match": ".",
					"name": "keyword.operator.dot.unimap"
				}, {
					"match": ":",
					"name": "keyword.operator.colon.unimap"
				}, {
					"match": "|",
					"name": "keyword.operator.or.unimap"
				}
			]
		},
		"punctuation": {
			"patterns": [
				{
					"match": "{",
					"name": "punctuation.brackets.curly.start.unimap"
				}, {
					"match": "}",
					"name": "punctuation.brackets.curly.start.unimap"
				}, {
					"match": "[",
					"name": "punctuation.brackets.square.start.unimap"
				}, {
					"match": "]",
					"name": "punctuation.brackets.square.start.unimap"
				}, {
					"match": "(",
					"name": "punctuation.brackets.round.start.unimap"
				}, {
					"match": ")",
					"name": "punctuation.brackets.round.start.unimap"
				}, {
        			"match": ",",
        			"name": "punctuation.separator.comma.unimap"
        		}, {
        			"match": ";",
        			"name": "punctuation.separator.semicolon.unimap"
        		}, {
        			"match": ",",
        			"name": "punctuation.separator.unimap"
        		}, {
        			"match": ",",
        			"name": "punctuation.separator.unimap"
        		}
			]
		},
		"nb": {
			"patterns": [{
				"name": "constant.numeric.unimap",
				"match": "(?<=^|\\s|[.:,;=|/(){}\\[\\]])((?![.:,;=|/(){}\\[\\]])[0-9]+(?=\\s|[.:,;=|/(){}\\[\\]]"
			}]
		},
		"identifiers": {
			"patterns": [
				{
					"name": "entity.name.function.unimap",
					"match": "(?<=^|\\s|[.:,;=|/(){}\\[\\]])((?![.:,;=|/(){}\\[\\]])[\\p{L}\\p{M}\\p{N}\\p{P}\\p{S}])+(?=\\s*\\()"
				},
				{
					"name": "variable.other.unimap",
					"match": "(?<=^|\\s|[.:,;=|/(){}\\[\\]])((?![.:,;=|/(){}\\[\\]])[\\p{L}\\p{M}\\p{N}\\p{P}\\p{S}])+"
				}
			]
		}
	}
}